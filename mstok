function onAirlineDropdown(sel) {
  airlineFilter = sel.value;
  // sync pills
  document.querySelectorAll('.airline-pill').forEach(function(p){ p.classList.remove('active'); });
  var matchPill = Array.from(document.querySelectorAll('.airline-pill')).find(function(p){
    return p.getAttribute('onclick') && p.getAttribute('onclick').indexOf("'"+airlineFilter+"'") !== -1;
  });
  if (matchPill) matchPill.classList.add('active');
  sel.classList.toggle('on', airlineFilter !== 'all');
