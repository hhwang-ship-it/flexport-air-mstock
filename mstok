  var to      = document.getElementById('r-to').value.trim();
  var memo    = document.getElementById('r-memo').value.trim();
  if (!prefix||prefix.length!==3) { markErr('r-prefix','Prefix는 3자리'); return; }
  if (!from||!to) { showToast('시작/끝 번호를 입력하세요', true); return; }
  var fromN = parseInt(from,10);
  var toN   = parseInt(to,10);
  if (isNaN(fromN)||isNaN(toN)||toN<fromN) { showToast('번호 범위가 잘못됐어요', true); return; }
  var count = toN - fromN + 1;
  if (count > 500) { showToast('한 번에 최대 500개까지 추가 가능해요', true); return; }
  setLoad(true);
  try {
    var rows = [];
    for (var n = fromN; n <= toN; n++) {
      var numStr = String(n).padStart(8,'0');
      if (!stocks.find(function(s){return s.prefix===prefix&&s.number===numStr;})) {
        rows.push({id:uid(), prefix:prefix, number:numStr, airline:airline, used:false, memo:memo});
      }
    }
    // Insert in batches of 100
    for (var i=0; i<rows.length; i+=100) {
      await sbPost('mawb_stock', rows.slice(i,i+100));
    }
    closeRangeModal();
    await loadAll();
    showToast(rows.length+'개 추가됨 ✓');
  } catch(e) { showToast('추가 실패: '+e.message, true); }
  finally { setLoad(false); }
}

// ── ASSIGN MODAL ──
function openAssignModal(stockId, mawbLabel) {
  assigningId = stockId;
  assignSelectedSid = null;
  document.getElementById('assignMawbLabel').textContent = mawbLabel;
  document.getElementById('assignSearch').value = '';
  renderAssignOpts();
  document.getElementById('assignOverlay').classList.add('open');
  setTimeout(function(){ document.getElementById('assignSearch').focus(); }, 50);
}
function closeAssignModal() { document.getElementById('assignOverlay').classList.remove('open'); assigningId=null; }

function renderAssignOpts() {
  var q = (document.getElementById('assignSearch').value||'').toLowerCase();
  // Show shipments with no mawb assigned
  var opts = shipments.filter(function(s) {
    if (s.mawb) return false; // already has mawb
    if (q) {
      var hay = [(s.flexId||''),(s.client||''),(s.dest||'')].join(' ').toLowerCase();
      return hay.indexOf(q) !== -1;
    }
    return true;
  });
  var el = document.getElementById('assignOpts');
  if (opts.length === 0) {
    el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--text3);font-size:12px;">MAWB 미배정 Shipment가 없어요</div>';
    return;
  }
  el.innerHTML = opts.map(function(s) {
    var isSel = assignSelectedSid === s.id;
    return '<div class="assign-opt'+(isSel?' sel':'')+'" onclick="selectAssignOpt(\''+s.id+'\')">'
      + '<div class="assign-opt-id">'+(s.flexId||'TBA')+'</div>'
      + '<div class="assign-opt-client">'+(s.client||'—')+'</div>'
      + '<div class="assign-opt-dest">'+(s.dest||'')+'</div>'
      + '</div>';
  }).join('');
}

function selectAssignOpt(sid) {
  assignSelectedSid = sid;
  renderAssignOpts();
}

async function confirmAssign() {
  if (!assigningId || !assignSelectedSid) { showToast('Shipment를 선택해주세요', true); return; }
  var stock   = stocks.find(function(s){return s.id===assigningId;});
  var ship    = shipments.find(function(s){return s.id===assignSelectedSid;});
  if (!stock||!ship) return;
  var mawb = stock.prefix+' '+stock.number.slice(0,4)+' '+stock.number.slice(4);
  setLoad(true);
  try {
    // Update mawb_stock → used
    await sbPatch('mawb_stock', assigningId, {
      used: true, flex_id: ship.flexId, client: ship.client,
      assigned_at: new Date().toISOString()
    });
    // Update shipment → mawb
    await sbPatch('shipments', assignSelectedSid, {
      mawb: mawb,
      plan_data: Object.assign({}, ship.planData||{}, {mawb: mawb})
    });
    closeAssignModal();
    await loadAll();
    showToast(mawb+' → '+ship.flexId+' 배정 완료 ✓');
  } catch(e) { showToast('배정 실패: '+e.message, true); }
  finally { setLoad(false); }
}

// ── UNASSIGN ──
async function unassign(stockId) {
  if (!confirm('배정을 해제할까요? Shipment의 MAWB도 삭제됩니다.')) return;
  var stock = stocks.find(function(s){return s.id===stockId;});
  if (!stock) return;
  setLoad(true);
  try {
    // Find shipment by flex_id and clear mawb
    var ship = shipments.find(function(s){return s.flexId===stock.flex_id;});
    if (ship) await sbPatch('shipments', ship.id, {mawb:''});
    await sbPatch('mawb_stock', stockId, {used:false, flex_id:null, client:null, assigned_at:null});
    await loadAll();
    showToast('배정 해제됨');
  } catch(e) { showToast('해제 실패: '+e.message, true); }
  finally { setLoad(false); }
}

// ── DELETE ──
async function deleteStock(stockId) {
  if (!confirm('이 MAWB를 삭제할까요?')) return;
  setLoad(true);
  try {
    await sbDelete('mawb_stock', stockId);
    stocks = stocks.filter(function(s){return s.id!==stockId;});
    renderKPIs(); renderAirlines(); renderTable();
    showToast('삭제됨');
  } catch(e) { showToast('삭제 실패: '+e.message, true); }
  finally { setLoad(false); }
}

// ── UTILS ──
function populateAirlineSelects() {
  var allForSelect = AIRLINES.concat(EXTRA_AIRLINES.filter(function(e){
    return !AIRLINES.find(function(a){ return a.code === e.code; });
  }));
  var mainGroup = '<optgroup label="주요 항공사">'
    + AIRLINES.map(function(a){ return '<option value="'+a.code+'">'+a.code+' · '+a.name+'</option>'; }).join('')
    + '</optgroup>';
  var extraGroup = '<optgroup label="기타">'
    + EXTRA_AIRLINES.filter(function(e){ return !AIRLINES.find(function(a){ return a.code===e.code; }); })
      .map(function(a){ return '<option value="'+a.code+'">'+a.code+' · '+a.name+'</option>'; }).join('')
    + '</optgroup>';
  var opts = '<option value="">선택</option>' + mainGroup + extraGroup;
  document.getElementById('a-airline').innerHTML = opts;
  document.getElementById('r-airline').innerHTML = opts;
  if (document.getElementById('mg-airline')) {
    document.getElementById('mg-airline').innerHTML = opts;
  }
}

function markErr(id, msg) {
  var el = document.getElementById(id);
  if (el) { el.classList.add('err'); el.focus(); el.addEventListener('input',function(){el.classList.remove('err');},{once:true}); }
  showToast(msg, true);
}

function esc(str) {
  return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

var _toastTimer;
function showToast(msg, isErr) {
  var el = document.getElementById('toast');
  el.textContent = msg;
  el.style.background = isErr ? 'var(--red)' : 'var(--text1)';
  el.classList.add('show');
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(function(){ el.classList.remove('show'); }, 2500);
}

// ── OVERLAY CLOSE ──
['addOverlay','rangeOverlay','assignOverlay','manageAirlinesOverlay'].forEach(function(id){
  document.getElementById(id).addEventListener('click', function(e){
    if (e.target===this) this.classList.remove('open');
  });
});

// ── NAV DATE ──
document.getElementById('navDate').textContent =
  new Date().toLocaleDateString('ko-KR',{year:'numeric',month:'long',day:'numeric',weekday:'short'});

// ── INIT ──
// Create table if doesn't exist — handled via SQL
loadAll();
setInterval(function(){
  var anyOpen = ['addOverlay','rangeOverlay','assignOverlay'].some(function(id){
    return document.getElementById(id).classList.contains('open');
  });
  if (!anyOpen) loadAll();
}, 30000);
</script>
