function updateRangePreview() {
  var from = document.getElementById('r-from').value.trim();
  var to   = document.getElementById('r-to').value.trim();
  var pfx  = document.getElementById('r-prefix').value.trim();
  var prev = document.getElementById('rangePreview');
  if (!from || !to || !pfx) { prev.style.display='none'; return; }
  var fromN = parseInt(from,10);
  var toN   = parseInt(to,10);
  if (isNaN(fromN)||isNaN(toN)||toN<fromN) { prev.style.display='none'; return; }
  var count = toN - fromN + 1;
  prev.style.display = 'block';
  prev.innerHTML = '<strong>'+count+'개</strong> 생성 예정 · '
    + pfx+'-'+String(fromN).padStart(8,'0')+' ~ '+pfx+'-'+String(toN).padStart(8,'0');
  if (count > 500) prev.innerHTML += ' <span style="color:var(--red);">⚠ 500개 초과 불가</span>';
}

