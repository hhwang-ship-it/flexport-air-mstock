  var byPrefix = {};
  stocks.forEach(function(s) {
    if (!byPrefix[s.prefix]) byPrefix[s.prefix] = {total:0, avail:0};
    byPrefix[s.prefix].total++;
    if (!s.used) byPrefix[s.prefix].avail++;
  });
  var prefixes = Object.keys(byPrefix);
  var h = '<div class="airline-pill '+(airlineFilter==='all'?'active':'')+'" onclick="setAirline(\'all\',this)">'
    + '<span class="airline-pill-code">전체</span>'
    + '<div class="airline-pill-counts">'
    + '<span class="ap-avail">'+stocks.filter(function(s){return !s.used;}).length+'</span>'
    + '<span class="ap-used">'+stocks.filter(function(s){return s.used;}).length+'</span>'
    + '</div></div>';
  prefixes.forEach(function(pfx) {
    var al = getAirline(pfx);
    var cnt = byPrefix[pfx];
    h += '<div class="airline-pill '+(airlineFilter===pfx?'active':'')+'" onclick="setAirline(\''+pfx+'\',this)">'
      + '<span class="airline-pill-code">'+pfx+'</span>'
      + '<span style="font-size:11px;color:var(--text2);">'+al.code+'</span>'
      + '<div class="airline-pill-counts">'
      + '<span class="ap-avail">'+cnt.avail+'</span>'
      + '<span class="ap-used">'+(cnt.total-cnt.avail)+'</span>'
      + '</div></div>';
  });
  bar.innerHTML = h;
  updateAirlineDropdown();
}

