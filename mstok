<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MAWB Stock — Flexport Air</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --teal:#45dabe; --teal-dim:#2bb8a0; --teal-bg:#e8faf6; --teal-dark:#0f6e56;
  --bg:#f5f4f1; --surface:#ffffff; --surface2:#f8f7f4;
  --border:#e4e2dc; --border2:#d0cec7;
  --text1:#1a1916; --text2:#5a5850; --text3:#9a9890;
  --red:#e24b4a; --red-bg:#fff0f0;
  --amber:#ba7517; --amber-bg:#fef9ee;
  --r-sm:6px; --r-md:10px; --r-lg:14px;
  --shadow:0 1px 3px rgba(0,0,0,.06),0 4px 16px rgba(0,0,0,.04);
  --shadow-lg:0 8px 32px rgba(0,0,0,.12),0 2px 8px rgba(0,0,0,.06);
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text1);font-size:13px;line-height:1.5;}
/* NAV */
.topnav{height:52px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:12px;position:sticky;top:0;z-index:100;}
.logo{display:flex;align-items:center;gap:8px;font-size:14px;font-weight:600;text-decoration:none;color:var(--text1);}
.logo-mark{width:26px;height:26px;border-radius:8px;background:var(--text1);display:flex;align-items:center;justify-content:center;}
.logo-sep{width:1px;height:18px;background:var(--border);margin:0 2px;}
.logo-sub{font-size:12px;font-weight:400;color:var(--text3);}
.nav-back{font-size:12px;color:var(--text2);text-decoration:none;display:flex;align-items:center;gap:4px;padding:4px 8px;border-radius:var(--r-sm);transition:background .12s;}
.nav-back:hover{background:var(--surface2);}
.nav-spacer{flex:1;}
.nav-date{font-size:11px;color:var(--text3);}
/* PAGE */
.page{max-width:1200px;margin:0 auto;padding:24px 24px 60px;}
.page-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;gap:16px;}
.page-title{font-size:22px;font-weight:600;letter-spacing:-.02em;}
.page-sub{font-size:12px;color:var(--text3);margin-top:3px;}
.page-actions{display:flex;gap:8px;flex-shrink:0;}
/* KPI CARDS */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px;}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px 18px;}
.kpi-label{font-size:11px;font-weight:600;color:var(--text3);letter-spacing:.04em;text-transform:uppercase;margin-bottom:8px;}
.kpi-val{font-size:28px;font-weight:600;letter-spacing:-.02em;font-family:'DM Mono',monospace;}
.kpi-sub{font-size:11px;color:var(--text3);margin-top:4px;}
.kpi-val.green{color:var(--teal-dark);}
.kpi-val.amber{color:var(--amber);}
.kpi-val.red{color:var(--red);}
/* AIRLINE PILLS */
.airline-bar{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;}
.airline-pill{display:flex;align-items:center;gap:8px;padding:8px 14px;border-radius:var(--r-md);border:1px solid var(--border);background:var(--surface);cursor:pointer;transition:all .12s;font-size:12px;}
.airline-pill:hover{border-color:var(--border2);background:var(--surface2);}
.airline-pill.active{border-color:var(--teal);background:var(--teal-bg);}
.airline-pill-code{font-weight:700;font-family:'DM Mono',monospace;font-size:13px;}
.airline-pill.active .airline-pill-code{color:var(--teal-dark);}
.airline-pill-counts{display:flex;gap:4px;}
.ap-avail{font-size:10px;font-weight:600;background:var(--teal-bg);color:var(--teal-dark);padding:1px 6px;border-radius:10px;}
.ap-used{font-size:10px;font-weight:600;background:var(--surface2);color:var(--text3);padding:1px 6px;border-radius:10px;}
/* TOOLBAR */
.toolbar{display:flex;align-items:center;gap:8px;margin-bottom:12px;}
.search-box{display:flex;align-items:center;gap:6px;border:1px solid var(--border);border-radius:var(--r-sm);padding:6px 10px;background:var(--surface);width:240px;}
.search-box input{border:none;outline:none;background:none;font-size:12px;font-family:inherit;color:var(--text1);width:100%;}
.search-box input::placeholder{color:var(--text3);}
.filter-group{display:flex;gap:4px;}
.filter-chip{font-size:11px;font-weight:500;padding:5px 12px;border-radius:20px;border:1px solid var(--border);background:var(--surface);color:var(--text2);cursor:pointer;transition:all .12s;}
.filter-chip:hover{border-color:var(--border2);}
.filter-chip.on{background:var(--teal-bg);border-color:var(--teal);color:var(--teal-dark);}
.tspc{flex:1;}
.airline-select-wrap{position:relative;display:inline-flex;align-items:center;}
.airline-select-wrap svg{position:absolute;right:8px;pointer-events:none;color:var(--text3);}
.airline-dropdown{appearance:none;border:1px solid var(--border);border-radius:var(--r-sm);padding:5px 28px 5px 10px;font-size:12px;font-family:'DM Sans',sans-serif;font-weight:500;color:var(--text1);background:var(--surface);cursor:pointer;outline:none;transition:border-color .12s;min-width:120px;}
.airline-dropdown:focus,.airline-dropdown:hover{border-color:var(--border2);}
.airline-dropdown.on{border-color:var(--teal);background:var(--teal-bg);color:var(--teal-dark);}
/* BUTTONS */
.btn{font-size:12px;font-weight:500;padding:7px 14px;border-radius:var(--r-sm);cursor:pointer;border:1px solid var(--border);background:var(--surface);color:var(--text1);font-family:inherit;display:inline-flex;align-items:center;gap:5px;transition:all .12s;}
.btn:hover{border-color:var(--border2);background:var(--surface2);}
.btn.primary{background:var(--text1);color:#fff;border-color:var(--text1);}
.btn.primary:hover{background:#2d2c29;}
.btn.teal{background:var(--teal);color:var(--teal-dark);border-color:var(--teal);font-weight:600;}
.btn.teal:hover{background:var(--teal-dim);}
.btn.sm{padding:4px 10px;font-size:11px;}
.btn.danger{color:var(--red);border-color:var(--red);}
/* TABLE */
.tbl-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;}
.data-table{width:100%;border-collapse:collapse;font-size:12px;}
.data-table th{padding:9px 12px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);border-bottom:1px solid var(--border);background:var(--surface2);white-space:nowrap;}
.data-table td{padding:10px 12px;border-bottom:1px solid var(--border);vertical-align:middle;}
.data-table tr:last-child td{border-bottom:none;}
.data-table tr:hover td{background:#f7fdfb;}
.data-table tr.used td{opacity:.55;}
.mono{font-family:'DM Mono',monospace;font-size:11.5px;}
.fw5{font-weight:500;}
/* STATUS BADGE */
.badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:600;padding:3px 8px;border-radius:20px;}
.badge-avail{background:var(--teal-bg);color:var(--teal-dark);}
.badge-used{background:var(--surface2);color:var(--text3);border:1px solid var(--border);}
.badge-low{background:var(--amber-bg);color:var(--amber);}
.badge-dot{width:5px;height:5px;border-radius:50%;background:currentColor;}
/* ASSIGN CHIP */
.assign-chip{display:inline-flex;align-items:center;gap:5px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--r-sm);padding:3px 8px;font-size:11px;}
.assign-chip .flex-id{font-family:'DM Mono',monospace;font-weight:500;color:var(--text1);}
.assign-chip .client{color:var(--text2);}
/* ASSIGN BUTTON */
.assign-btn{font-size:11px;font-weight:500;padding:3px 10px;border-radius:var(--r-sm);border:1px dashed var(--border2);background:none;color:var(--text3);cursor:pointer;font-family:inherit;transition:all .12s;}
.assign-btn:hover{border-color:var(--teal);color:var(--teal-dark);background:var(--teal-bg);}
/* EMPTY */
.empty{text-align:center;padding:48px 24px;color:var(--text3);}
.empty-icon{font-size:32px;margin-bottom:8px;opacity:.4;}
/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:200;display:none;align-items:center;justify-content:center;}
.overlay.open{display:flex;}
.modal{background:var(--surface);border-radius:var(--r-lg);box-shadow:var(--shadow-lg);width:520px;max-width:96vw;max-height:90vh;display:flex;flex-direction:column;animation:mIn .18s ease;}
@keyframes mIn{from{transform:translateY(12px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-hdr{padding:18px 20px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.modal-title{font-size:15px;font-weight:600;flex:1;}
.modal-x{width:28px;height:28px;border-radius:var(--r-sm);border:1px solid var(--border);background:none;cursor:pointer;color:var(--text3);font-size:16px;font-family:inherit;display:flex;align-items:center;justify-content:center;}
.modal-x:hover{background:var(--surface2);}
.modal-body{flex:1;overflow-y:auto;padding:18px 20px;}
.modal-ftr{padding:14px 20px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;}
/* FORM */
.fg{display:flex;flex-direction:column;gap:4px;margin-bottom:14px;}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.flabel{font-size:11px;font-weight:600;color:var(--text2);}
.flabel span{color:var(--red);}
.finput{border:1px solid var(--border);border-radius:var(--r-sm);padding:7px 10px;font-size:12px;font-family:inherit;color:var(--text1);background:var(--surface);outline:none;width:100%;transition:border-color .12s;}
.finput:focus{border-color:var(--teal);box-shadow:0 0 0 2px rgba(69,218,190,.12);}
.finput.err{border-color:var(--red);}
.finput::placeholder{color:var(--text3);}
.fsel{appearance:none;background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%239a9890' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 10px center;padding-right:28px;}
.fhint{font-size:10px;color:var(--text3);margin-top:2px;}
.fsep{height:1px;background:var(--border);margin:16px 0;}
.ftabs{display:flex;gap:2px;margin-bottom:16px;background:var(--surface2);padding:3px;border-radius:var(--r-md);}
.ftab{flex:1;text-align:center;padding:6px;font-size:12px;font-weight:500;color:var(--text2);cursor:pointer;border-radius:var(--r-sm);transition:all .12s;}
.ftab.active{background:var(--surface);color:var(--text1);box-shadow:0 1px 3px rgba(0,0,0,.08);}
/* RANGE PREVIEW */
.range-preview{background:var(--surface2);border-radius:var(--r-sm);padding:10px 12px;font-size:11px;color:var(--text2);margin-top:8px;}
.range-preview strong{color:var(--text1);}
/* ASSIGN MODAL */
.assign-search{display:flex;align-items:center;gap:8px;border:1px solid var(--border);border-radius:var(--r-sm);padding:7px 10px;margin-bottom:12px;}
.assign-search input{border:none;outline:none;font-size:12px;font-family:inherit;color:var(--text1);width:100%;}
.assign-opts{max-height:220px;overflow-y:auto;}
.assign-opt{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:var(--r-sm);cursor:pointer;transition:background .08s;}
.assign-opt:hover{background:var(--surface2);}
.assign-opt.sel{background:var(--teal-bg);}
.assign-opt-id{font-family:'DM Mono',monospace;font-size:11px;font-weight:500;color:var(--text1);min-width:70px;}
.assign-opt-client{font-size:12px;color:var(--text2);flex:1;}
.assign-opt-dest{font-size:11px;color:var(--text3);}
/* TOAST */
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:var(--text1);color:#fff;font-size:12px;font-weight:500;padding:8px 16px;border-radius:var(--r-md);z-index:9999;opacity:0;pointer-events:none;transition:opacity .2s;white-space:nowrap;}
.toast.show{opacity:1;}
/* LOADING */
#loadBar{display:none;position:fixed;top:0;left:0;width:100%;height:3px;background:var(--teal);z-index:9999;animation:ldp 1s ease infinite alternate;}
@keyframes ldp{from{opacity:.5}to{opacity:1}}
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}
</style>
</head>
<body>

<div id="loadBar"></div>

<nav class="topnav">
  <a class="logo" href="/">
    <div class="logo-mark"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="#45dabe" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    Flexport Korea
    <div class="logo-sep"></div>
    <span class="logo-sub">Air Planning</span>
  </a>
  <div class="nav-spacer"></div>
  <span class="nav-date" id="navDate"></span>
</nav>

<div class="page">
  <!-- PAGE HEADER -->
  <div class="page-hdr">
    <div>
      <div class="page-title">MAWB Stock</div>
      <div class="page-sub" id="pageSubtitle">로딩 중…</div>
    </div>
    <div class="page-actions">
      <button class="btn" onclick="openManageAirlinesModal()" title="항공사 탭 관리">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.3"/><path d="M6 3.5v2.5l1.5 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        항공사 관리
      </button>
      <button class="btn" onclick="openAddModal()">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M5.5 1v9M1 5.5h9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        단건 추가
      </button>
      <button class="btn teal" onclick="openRangeModal()">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1 6h10M6 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        범위 추가
      </button>
    </div>
  </div>

  <!-- KPI -->
  <div class="kpi-grid">
    <div class="kpi">
      <div class="kpi-label">전체 Stock</div>
      <div class="kpi-val" id="kpi-total">—</div>
      <div class="kpi-sub">등록된 MAWB 번호</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">사용 가능</div>
      <div class="kpi-val green" id="kpi-avail">—</div>
      <div class="kpi-sub">미배정 번호</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">사용 완료</div>
      <div class="kpi-val" id="kpi-used">—</div>
      <div class="kpi-sub">배정된 번호</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">잔여율</div>
      <div class="kpi-val amber" id="kpi-rate">—</div>
      <div class="kpi-sub">사용 가능 비율</div>
    </div>
  </div>

  <!-- AIRLINE PILLS -->
  <div class="airline-bar" id="airlineBar"></div>

  <!-- TOOLBAR -->
  <div class="toolbar">
    <div class="search-box">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="5" cy="5" r="3.5" stroke="#9a9890" stroke-width="1.3"/><path d="M8 8l2.5 2.5" stroke="#9a9890" stroke-width="1.3" stroke-linecap="round"/></svg>
      <input type="text" id="searchInput" placeholder="MAWB 번호, FLEX-ID, Client 검색…" oninput="renderTable()">
    </div>
    <div class="airline-select-wrap">
      <select class="airline-dropdown" id="airlineDropdown" onchange="onAirlineDropdown(this)">
        <option value="all">항공사 전체</option>
      </select>
      <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </div>
    <div class="filter-group">
      <div class="filter-chip on" id="fc-all" onclick="setFilter('all',this)">전체</div>
      <div class="filter-chip" id="fc-avail" onclick="setFilter('avail',this)">사용 가능</div>
      <div class="filter-chip" id="fc-used" onclick="setFilter('used',this)">사용 완료</div>
    </div>
    <div class="tspc"></div>
    <span id="syncStatus" style="font-size:11px;color:var(--text3);"></span>
  </div>

  <!-- TABLE -->
  <div class="tbl-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>항공사</th>
          <th>MAWB 번호</th>
          <th>상태</th>
          <th>배정된 Shipment</th>
          <th>등록일</th>
          <th style="width:80px;"></th>
        </tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
    <div class="empty" id="emptyState" style="display:none;">
      <div class="empty-icon">📋</div>
      <div style="font-size:14px;font-weight:500;margin-bottom:4px;">MAWB Stock이 없어요</div>
      <div style="font-size:12px;">단건 추가 또는 범위 추가로 시작해보세요</div>
    </div>
  </div>
</div>

<!-- 단건 추가 모달 -->
<div class="overlay" id="addOverlay">
  <div class="modal">
    <div class="modal-hdr">
      <div class="modal-title">MAWB 추가</div>
      <button class="modal-x" onclick="closeAddModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="fg2">
        <div class="fg">
          <label class="flabel">항공사 <span>*</span></label>
          <select class="finput fsel" id="a-airline">
            <option value="">선택</option>
          </select>
        </div>
        <div class="fg">
          <label class="flabel">Prefix <span>*</span></label>
          <input class="finput mono" id="a-prefix" placeholder="예: 180" maxlength="3">
          <div class="fhint">항공사 3자리 코드</div>
        </div>
      </div>
      <div class="fg">
        <label class="flabel">MAWB 번호 <span>*</span></label>
        <input class="finput mono" id="a-number" placeholder="예: 12345678" maxlength="8">
        <div class="fhint">8자리 숫자 (prefix 제외)</div>
      </div>
      <div class="fg">
        <label class="flabel">메모</label>
        <input class="finput" id="a-memo" placeholder="선택 입력">
      </div>
    </div>
    <div class="modal-ftr">
      <button class="btn" onclick="closeAddModal()">취소</button>
      <button class="btn primary" onclick="submitAdd()">추가</button>
    </div>
  </div>
</div>

<!-- 범위 추가 모달 -->
<div class="overlay" id="rangeOverlay">
  <div class="modal">
    <div class="modal-hdr">
      <div class="modal-title">범위 추가</div>
      <button class="modal-x" onclick="closeRangeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="fg2">
        <div class="fg">
          <label class="flabel">항공사 <span>*</span></label>
          <select class="finput fsel" id="r-airline">
            <option value="">선택</option>
          </select>
        </div>
        <div class="fg">
          <label class="flabel">Prefix <span>*</span></label>
          <input class="finput mono" id="r-prefix" placeholder="예: 180" maxlength="3">
        </div>
      </div>
      <div class="fg2">
        <div class="fg">
          <label class="flabel">시작 번호 <span>*</span></label>
          <input class="finput mono" id="r-from" placeholder="예: 00001000" maxlength="8" oninput="updateRangePreview()">
        </div>
        <div class="fg">
          <label class="flabel">끝 번호 <span>*</span></label>
          <input class="finput mono" id="r-to" placeholder="예: 00001099" maxlength="8" oninput="updateRangePreview()">
        </div>
      </div>
      <div class="range-preview" id="rangePreview" style="display:none;"></div>
      <div class="fg" style="margin-top:12px;">
        <label class="flabel">메모</label>
        <input class="finput" id="r-memo" placeholder="선택 입력">
      </div>
    </div>
    <div class="modal-ftr">
      <button class="btn" onclick="closeRangeModal()">취소</button>
      <button class="btn primary" onclick="submitRange()">일괄 추가</button>
    </div>
  </div>
</div>

<!-- 배정 모달 -->
<div class="overlay" id="assignOverlay">
  <div class="modal">
    <div class="modal-hdr">
      <div class="modal-title">Shipment 배정</div>
      <button class="modal-x" onclick="closeAssignModal()">✕</button>
    </div>
    <div class="modal-body">
      <div style="font-size:12px;color:var(--text2);margin-bottom:12px;">
        배정할 MAWB: <span class="mono fw5" id="assignMawbLabel"></span>
      </div>
