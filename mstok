  var rate  = total ? Math.round(avail/total*100) : 0;
  document.getElementById('kpi-total').textContent = total.toLocaleString();
  document.getElementById('kpi-avail').textContent = avail.toLocaleString();
  document.getElementById('kpi-used').textContent  = used.toLocaleString();
  var rateEl = document.getElementById('kpi-rate');
  rateEl.textContent = rate + '%';
  rateEl.className = 'kpi-val ' + (rate > 50 ? 'green' : rate > 20 ? 'amber' : 'red');
