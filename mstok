function syncAirlineDropdown() {
  var sel = document.getElementById('airlineDropdown');
  if (!sel) return;
  sel.value = airlineFilter;
  sel.classList.toggle('on', airlineFilter !== 'all');
}

function updateAirlineDropdown() {
  var sel = document.getElementById('airlineDropdown');
  if (!sel) return;
  // Count by prefix in stocks
  var byPrefix = {};
  stocks.forEach(function(s) {
    if (!byPrefix[s.prefix]) byPrefix[s.prefix] = {total:0, avail:0};
    byPrefix[s.prefix].total++;
    if (!s.used) byPrefix[s.prefix].avail++;
  });
  var opts = '<option value="all">항공사 전체</option>';
  // Show AIRLINES first
  AIRLINES.forEach(function(a) {
    var cnt = byPrefix[a.prefix];
    var label = a.code + ' · ' + a.name + (cnt ? ' ('+cnt.avail+'/'+cnt.total+')' : '');
    opts += '<option value="'+a.prefix+'">'+label+'</option>';
  });
  // Show any other prefixes in stock not in AIRLINES
  Object.keys(byPrefix).forEach(function(pfx) {
    var inList = AIRLINES.find(function(a){ return a.prefix === pfx; });
    if (!inList) {
      var al = getAirline(pfx);
      var cnt = byPrefix[pfx];
      opts += '<option value="'+pfx+'">'+al.code+' ('+cnt.avail+'/'+cnt.total+')</option>';
    }
  });
  sel.innerHTML = opts;
  sel.value = airlineFilter;
  sel.classList.toggle('on', airlineFilter !== 'all');
}

